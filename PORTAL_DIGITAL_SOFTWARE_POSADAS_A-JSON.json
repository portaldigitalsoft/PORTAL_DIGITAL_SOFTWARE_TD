  "html_body_close": "<script src=\"https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js\"></script>\n\n<div id=\"contenedor_acordeon_qr\" style=\"text-align: center; margin: 25px auto; max-width: 370px; font-family: sans-serif;\">\n    \n    <button id=\"btn_acordeon\" onclick=\"toggleAcordeon()\" style=\"background: none; border: 2px solid #D4AF37; color: #D4AF37; padding: 12px 25px; border-radius: 50px; cursor: pointer; font-weight: bold; font-size: 0.85rem; letter-spacing: 1px; transition: 0.3s; width: 100%;\">\n        🔲 MOSTRAR CÓDIGO QR\n    </button>\n\n    <div id=\"display_qr\" style=\"display: none; margin-top: 20px; padding: 25px; background: linear-gradient(135deg, #1a1a1a, #000); border: 2px solid #D4AF37; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.8); position: relative;\">\n        \n        <div style=\"position: absolute; top: -11px; left: 50%; transform: translateX(-50%); width: 0; height: 0; border-left: 10px solid transparent; border-right: 10px solid transparent; border-bottom: 10px solid #D4AF37;\"></div>\n\n        <div id=\"qrcode\" style=\"background: white; padding: 15px; border-radius: 12px; display: inline-block; line-height: 0;\"></div>\n        \n        <p style=\"color: #D4AF37; font-size: 0.75rem; margin: 15px 0 20px 0; font-weight: 900; letter-spacing: 2px; text-transform: uppercase;\">\n            Escaneame con la cámara\n        </p>\n\n        <button onclick=\"compartirNativo()\" style=\"background: #D4AF37; border: none; color: #000; padding: 10px 20px; border-radius: 50px; cursor: pointer; font-weight: bold; font-size: 0.8rem; width: 90%; display: flex; align-items: center; justify-content: center; margin: 0 auto;\">\n            📲 COMPARTIR TARJETA\n        </button>\n    </div>\n</div>\n\n<script>\nlet qrGenerado = false;\n\nfunction toggleAcordeon() {\n    const contenedor = document.getElementById('display_qr');\n    const btn = document.getElementById('btn_acordeon');\n    const qrDiv = document.getElementById('qrcode');\n\n    if (contenedor.style.display === \"none\" || contenedor.style.display === \"\") {\n        // Abrir\n        contenedor.style.display = \"inline-block\";\n        btn.innerHTML = \"✖️ CERRAR QR\";\n        \n        if (!qrGenerado) {\n            new QRCode(qrDiv, {\n                text: window.location.href,\n                width: 180,\n                height: 180,\n                colorDark : \"#000000\",\n                colorLight : \"#ffffff\",\n                correctLevel : QRCode.CorrectLevel.H\n            });\n            qrGenerado = true;\n        }\n        contenedor.scrollIntoView({ behavior: 'smooth', block: 'nearest' });\n    } else {\n        // Cerrar\n        contenedor.style.display = \"none\";\n        btn.innerHTML = \"🔲 MOSTRAR CÓDIGO QR\";\n    }\n}\n\nasync function compartirNativo() {\n    const compartirData = {\n        title: 'Mi Tarjeta Digital',\n        text: '¡Hola! Te comparto mi tarjeta de contacto digital. Puedes verla aquí:',\n        url: window.location.href\n    };\n\n    // Lógica para Celulares (Android/iOS)\n    if (navigator.share) {\n        try {\n            await navigator.share(compartirData);\n        } catch (err) {\n            console.log(\"Compartir cancelado\");\n        }\n    } \n    // Lógica para Computadoras (PC/Mac)\n    else {\n        // Copia el enlace al portapapeles y avisa al usuario\n        navigator.clipboard.writeText(window.location.href).then(() => {\n            alert(\"Enlace copiado al portapapeles. ¡Ya puedes pegarlo donde quieras!\");\n        }).catch(err => {\n            alert(\"Para compartir en PC, copia la URL de la barra de direcciones.\");\n        });\n    }\n}\n</script>\n",
